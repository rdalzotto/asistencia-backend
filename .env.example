# ══════════════════════════════════════════════════════════════
# AsistenciaAR — Variables de entorno
# Copiar como .env y completar los valores reales
# ══════════════════════════════════════════════════════════════

# ─── Base de datos (Supabase) ──────────────────────────────────
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_cadena_muy_larga_y_aleatoria_minimo_64_caracteres

# ─── Web Push (VAPID) ─────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@tu-empresa.com

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=https://roaring-dolphin-29bc4e.netlify.app

# ─── Datos iniciales del empleador (para seed) ────────────────
RAZON_SOCIAL=EXIT SRL
NOMBRE_FANTASIA=EXIT
CUIT=30-00000000-0
DOMICILIO=Dirección de la empresa
LOCALIDAD=Concordia
PROVINCIA=Entre Ríos

# ─── Admin inicial ────────────────────────────────────────────
ADMIN_EMAIL=ingrogeliodalzotto@gmail.com
ADMIN_PASSWORD=CambiarEstaPassword123!

# ─── Configuración operativa ──────────────────────────────────
# Puerto del servidor
PORT=3000

# Hora de cierre automático de jornada (formato 24hs, Argentina)
HORA_CIERRE_AUTO=20

# Entorno
NODE_ENV=production
